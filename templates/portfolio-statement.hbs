<!doctype html>
<html>
  <head>
    <style>
      @page {
        size: Letter;
        margin: 2.4cm 2cm 2.2cm;
        @top-left {
          content: string(doctitle);
          font:
            8pt Georgia,
            serif;
          color: #667;
        }
        @top-right {
          content: "{{data.statementPeriod}}";
          font:
            8pt Georgia,
            serif;
          color: #667;
        }
        @bottom-left {
          content: "Confidential";
          font:
            8pt Georgia,
            serif;
          color: #a2472f;
        }
        @bottom-right {
          content: "Page " counter(page) " of " counter(pages);
          font:
            8pt Georgia,
            serif;
          color: #889;
        }
      }
      body {
        font-family: Georgia, "Times New Roman", serif;
        color: #1a1f2b;
        font-size: 10.5pt;
        line-height: 1.45;
      }
      .masthead {
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 2px solid #16233f;
        padding-bottom: 10pt;
        margin-bottom: 14pt;
      }
      .masthead img {
        height: 40px;
        width: auto;
      }
      .masthead h1 {
        font-size: 16pt;
        margin: 0;
        string-set: doctitle content();
      }
      .masthead .meta {
        margin-left: auto;
        text-align: right;
        font-size: 9pt;
        color: #556;
        line-height: 1.4;
      }
      h2 {
        font-size: 12pt;
        margin: 16pt 0 6pt;
        color: #16233f;
        border-bottom: 1px solid #d7dbe4;
        padding-bottom: 3pt;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      thead th {
        background: #16233f;
        color: #fff;
        font-size: 8pt;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 6pt 8pt;
        text-align: left;
      }
      thead th.num {
        text-align: right;
      }
      tbody td {
        padding: 4.5pt 8pt;
        border-bottom: 1px solid #e7eaf1;
      }
      td.sym {
        font-family: "Courier New", monospace;
        font-size: 9pt;
        color: #556;
      }
      td.num {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      tbody tr {
        break-inside: avoid;
      }
      tfoot td {
        padding: 7pt 8pt;
        border-top: 2px solid #16233f;
        font-weight: bold;
      }
      tfoot td.num {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      .callout {
        break-inside: avoid;
        background: #f3f5f9;
        border-left: 3px solid #16233f;
        padding: 8pt 12pt;
        margin: 16pt 0;
        font-size: 9.5pt;
        color: #333;
      }
    </style>
  </head>
